//=====================================
// INPUT CONFIGURATION
//=====================================
// https://niri-wm.github.io/niri/Configuration%3A-Input.html

input {
    keyboard {
        xkb {
            layout "us"
        }
    }

    touchpad {
        tap
        accel-speed 0.2
        accel-profile "adaptive"
        scroll-method "two-finger"
        natural-scroll
    }

    mouse {
        accel-profile "flat"
    }

    focus-follows-mouse
}

cursor {
    xcursor-size 20
    hide-when-typing
    hide-after-inactive-ms 1000
}